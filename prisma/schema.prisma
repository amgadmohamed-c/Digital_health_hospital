// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  DOCTOR
  NURSE
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

enum AppointmentType {
  HOSPITAL
  ONLINE
}

enum AppointmentStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum QueueStatus {
  WAITING
  IN_PROGRESS
  DONE
}

enum SenderType {
  DOCTOR
  PATIENT
}

enum RoomType {
  SURGERY
  EMERGENCY
}

enum SurgeryStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── Users & Roles ───────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  gender    Gender   @default(MALE)
  age       Int
  password  String
  role      Role     @default(PATIENT)
  create_at DateTime @default(now())

  patient Patient?
  doctor  Doctor?
  nurse   Nurse?
}

model Patient {
  id        String  @id @default(uuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id])
  bloodtype String?
  allergies String?
  img       String?

  visits          Visit[]
  appointments    Appointment[]
  records         MedicalRecord[]
  emergencyQueues EmergencyQueue[]
  vitals          Vital[]
  surgeries       Surgery[]

  createdAt DateTime @default(now())
}

model Doctor {
  id             String     @id @default(uuid())
  userId         String     @unique
  user           User       @relation(fields: [userId], references: [id])
  specialization String
  departmentId   String
  department     Department @relation(fields: [departmentId], references: [id])
  img            String?
  bio            String?

  appointments    Appointment[]
  visits          Visit[]
  surgeries       Surgery[]
  emergencyQueues EmergencyQueue[]

  createdAt DateTime @default(now())
}

model Nurse {
  id           String     @id @default(uuid())
  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id])
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Departments & Rooms ─────────────────────────────────────────────────────

model Department {
  id   String @id @default(uuid())
  name String @unique

  doctors         Doctor[]
  nurses          Nurse[]
  visits          Visit[]
  appointments    Appointment[]
  emergencyQueues EmergencyQueue[]
  rooms           Room[]
}

model Room {
  id           String     @id @default(uuid())
  name         String
  type         RoomType
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  visits    Visit[]
  surgeries Surgery[]

  createdAt DateTime @default(now())
}

// ─── Appointments & Visits ───────────────────────────────────────────────────

model Appointment {
  id           String @id @default(uuid())
  patientId    String
  doctorId     String
  departmentId String

  patient    Patient    @relation(fields: [patientId], references: [id])
  doctor     Doctor     @relation(fields: [doctorId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  type   AppointmentType
  status AppointmentStatus

  scheduledAt DateTime
  chatSession ChatSession?

  createdAt DateTime @default(now())
}

model Visit {
  id           String  @id @default(uuid())
  patientId    String
  doctorId     String
  departmentId String
  roomId       String?

  patient    Patient    @relation(fields: [patientId], references: [id])
  doctor     Doctor     @relation(fields: [doctorId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  room       Room?      @relation(fields: [roomId], references: [id])

  diagnosis String?
  notes     String?

  createdAt DateTime @default(now())
}

// ─── Emergency ───────────────────────────────────────────────────────────────

model EmergencyQueue {
  id           String     @id @default(uuid())
  patientId    String
  patient      Patient    @relation(fields: [patientId], references: [id])
  doctorId     String?
  doctor       Doctor?    @relation(fields: [doctorId], references: [id])
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  priority    Priority
  status      QueueStatus
  arrivalTime DateTime    @default(now())

  surgery Surgery?
}

// ─── Surgery ─────────────────────────────────────────────────────────────────

model Surgery {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])
  surgeonId String
  surgeon   Doctor  @relation(fields: [surgeonId], references: [id])
  roomId    String
  room      Room    @relation(fields: [roomId], references: [id])

  // link back to the emergency queue entry that triggered this (if any)
  emergencyQueueId String?        @unique
  emergencyQueue   EmergencyQueue? @relation(fields: [emergencyQueueId], references: [id])

  status    SurgeryStatus
  notes     String?

  scheduledAt DateTime? // null = unscheduled / emergency surgery
  startedAt   DateTime?
  endedAt     DateTime?

  createdAt DateTime @default(now())
}

// ─── Chat ────────────────────────────────────────────────────────────────────

model ChatSession {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  messages  Message[]
  startedAt DateTime?
  endedAt   DateTime?
}

model Message {
  id         String      @id @default(uuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id])
  senderId   String
  senderType SenderType
  content    String

  createdAt DateTime @default(now())
}

// ─── Medical Data ────────────────────────────────────────────────────────────

model MedicalRecord {
  id        String   @id @default(uuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
  title     String
  fileUrl   String[]

  createdAt DateTime @default(now())
}

model Vital {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  heartRate     Int?
  bloodPressure String?
  temperature   Float?

  recordedAt DateTime @default(now())
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
