// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  PATIENT
  DOCTOR
  NURSE
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

enum AppointmentType {
  HOSPITAL
  ONLINE
}

enum AppointmentStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum QueueStatus {
  WAITING
  IN_TREATMENT
  STABLE
  ADMITTED
  DISCHARGED
}

enum SenderType {
  DOCTOR
  PATIENT
}

enum RoomType {
  SURGERY
  EMERGENCY
}

// [MODIFIED] Added AVAILABLE, OCCUPIED, MAINTENANCE to track real-time room occupancy
enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum SurgeryStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// [NEW] Distinguishes scheduled vs emergency vs urgent surgeries
enum SurgeryType {
  SCHEDULED
  EMERGENCY
  URGENT
}

// [NEW] Tracks pre-op preparation task status
enum PrepStatus {
  PENDING
  READY
  FAILED
}

// ─── Users & Roles ───────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  ssn       String   @default("0")
  name      String
  email     String   @unique
  phone     String
  gender    Gender   @default(MALE)
  age       Int
  password  String
  role      Role     @default(PATIENT)
  create_at DateTime @default(now())

  patient Patient?
  doctor  Doctor?
  nurse   Nurse?
}

model Patient {
  id        String  @id @default(uuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id])
  bloodtype String?
  allergies String?
  img       String?

  visits          Visit[]
  appointments    Appointment[]
  records         MedicalRecord[]
  emergencyQueues EmergencyQueue[]
  vitals          Vital[]
  surgeries       Surgery[]

  createdAt DateTime @default(now())
}

model Doctor {
  id             String     @id @default(uuid())
  userId         String     @unique
  user           User       @relation(fields: [userId], references: [id])
  specialization String
  departmentId   String
  department     Department @relation(fields: [departmentId], references: [id])
  img            String?
  bio            String?
  experience     String?

  appointments       Appointment[]
  visits             Visit[]
  surgeries          Surgery[]
  emergencyQueues    EmergencyQueue[]
  // [MODIFIED] Replaced bare Availability with richer weekly schedule + exceptions
  availability       Availability[]
  scheduleExceptions ScheduleException[]

  createdAt DateTime @default(now())
}

model Nurse {
  id           String     @id @default(uuid())
  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id])
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Departments & Rooms ─────────────────────────────────────────────────────

model Department {
  id   String @id @default(uuid())
  name String @unique

  doctors         Doctor[]
  nurses          Nurse[]
  visits          Visit[]
  appointments    Appointment[]
  emergencyQueues EmergencyQueue[]
  rooms           Room[]
}

model Room {
  id           String     @id @default(uuid())
  name         String
  type         RoomType
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  // [NEW] Real-time room occupancy status
  status       RoomStatus @default(AVAILABLE)

  visits    Visit[]
  surgeries Surgery[]
  devices   MedicalDevice[]  // ADD THIS LINE


  createdAt DateTime @default(now())
}

// ─── Availability & Scheduling ───────────────────────────────────────────────

// [MODIFIED] Replaced the bare boolean Availability with a full weekly schedule model
model Availability {
  id       String  @id @default(uuid())
  doctorId String
  doctor   Doctor  @relation(fields: [doctorId], references: [id])

  dayOfWeek     Int   // 0 = Sunday … 6 = Saturday
  startTime     String  // "09:00"
  endTime       String  // "17:00"
  slotDuration  Int     @default(30) // minutes per appointment slot
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())

  @@unique([doctorId, dayOfWeek, startTime])
}

// [NEW] One-off overrides: vacation days, sick days, or extra availability
model ScheduleException {
  id       String @id @default(uuid())
  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id])

  date      DateTime // the specific calendar date this exception applies to
  isBlocked Boolean  @default(true) // true = unavailable, false = extra availability added
  startTime String?  // only relevant when isBlocked = false
  endTime   String?  // only relevant when isBlocked = false
  reason    String?  // e.g. "Annual leave", "Conference", "Emergency cover"

  createdAt DateTime @default(now())

  @@unique([doctorId, date])
}

// ─── Appointments & Visits ───────────────────────────────────────────────────

model Appointment {
  id           String @id @default(uuid())
  patientId    String
  doctorId     String
  departmentId String
  

  patient    Patient    @relation(fields: [patientId], references: [id])
  doctor     Doctor     @relation(fields: [doctorId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  visit      Visit?     

  type   AppointmentType
  status AppointmentStatus

  scheduledAt      DateTime
  endsAt           DateTime
  // [NEW] Duration needed to detect slot conflicts
  durationMinutes  Int      @default(30)

  chatSession ChatSession?

  createdAt DateTime @default(now())
}

model Visit {
  id           String  @id @default(uuid())
  patientId    String
  doctorId     String
  departmentId String
  appointmentId String?  @unique
  roomId       String?


  patient    Patient    @relation(fields: [patientId], references: [id])
  doctor     Doctor     @relation(fields: [doctorId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  room       Room?      @relation(fields: [roomId], references: [id])
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])


  diagnosis String?
  notes     String?

  createdAt DateTime @default(now())
}

// ─── Emergency ───────────────────────────────────────────────────────────────

model EmergencyQueue {
  id           String     @id @default(uuid())
  patientId    String
  patient      Patient    @relation(fields: [patientId], references: [id])
  doctorId     String?
  doctor       Doctor?    @relation(fields: [doctorId], references: [id])
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  priority    Priority
  status      QueueStatus
  arrivalTime DateTime    @default(now())

  surgery Surgery?
}

// ─── Surgery ─────────────────────────────────────────────────────────────────

// [MODIFIED] Major overhaul — see modification listing below
model Surgery {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])
  surgeonId String
  surgeon   Doctor  @relation(fields: [surgeonId], references: [id])

  // [MODIFIED] roomId is now nullable — emergency surgeries grab a room on the fly
  roomId String?
  room   Room?   @relation(fields: [roomId], references: [id])

  emergencyQueueId String?         @unique
  emergencyQueue   EmergencyQueue? @relation(fields: [emergencyQueueId], references: [id])

  // [NEW] Explicit surgery type instead of inferring from scheduledAt being null
  type   SurgeryType
  surgeryStatus SurgeryStatus

  // [NEW] Priority pulled from existing enum — useful for URGENT triage ranking
  priority Priority?

  notes String?

  // Timing — all nullable to support unscheduled/emergency cases
  scheduledAt       DateTime? // null for emergency surgeries
  // [NEW] Estimated duration for room conflict detection
  estimatedDuration Int?      // minutes
  startedAt         DateTime?
  endedAt           DateTime?

  // [NEW] Audit trail — who ordered and who approved this surgery
  requestedBy String? // doctorId
  approvedBy  String? // adminId or senior doctorId

  // [NEW] Pre-op preparation tasks (only meaningful for SCHEDULED / URGENT)
  prepTasks SurgeryPrep[]

  createdAt DateTime @default(now())
}

// [NEW] Pre-operative preparation checklist per surgery
model SurgeryPrep {
  id        String  @id @default(uuid())
  surgeryId String
  surgery   Surgery @relation(fields: [surgeryId], references: [id])

  task        String     // e.g. "Blood work", "Anesthesia consult", "Patient fasting"
  status      PrepStatus @default(PENDING)
  assignedTo  String?    // nurseId or doctorId responsible for this task
  dueAt       DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
}

// ─── Chat ────────────────────────────────────────────────────────────────────

model ChatSession {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  messages  Message[]
  startedAt DateTime?
  endedAt   DateTime?
}

model Message {
  id         String      @id @default(uuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id])
  senderId   String
  senderType SenderType
  content    String

  createdAt DateTime @default(now())
}

// ─── Medical Data ────────────────────────────────────────────────────────────

model MedicalRecord {
  id        String   @id @default(uuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id] , onDelete :Cascade)
  title     String
  fileUrl   String[]

  createdAt DateTime @default(now())
}

model Vital {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  heartRate     Int?
  bloodPressure String?
  temperature   Float?

  recordedAt DateTime @default(now())
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}


//_____________________________________________________________________________
// ─── Medical Devices ─────────────────────────────────────────────────────────

enum DeviceStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OUT_OF_SERVICE
}

model MedicalDevice {
  id       String       @id @default(uuid())
  name     String
  type     String       // e.g. "Ventilator", "ECG Monitor", "Surgical Light"
  roomId   String
  room     Room         @relation(fields: [roomId], references: [id])
  status   DeviceStatus @default(AVAILABLE)
  serialNo String?

  createdAt DateTime @default(now())
}